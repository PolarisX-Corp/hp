# お問い合わせフォームのメール送信設定（Resend: https://resend.com）
# Vercel のプロジェクト設定 → Environment Variables に登録してください。

# Resend の API キー（必須。未設定だとフォーム送信は 503 を返します）
RESEND_API_KEY=

# 送信先メールアドレス（未設定時は contact@polarisx.ltd）
CONTACT_TO=contact@polarisx.ltd

# 送信元（Resend で検証済みのドメインを推奨。未設定時は onboarding@resend.dev）
# 例: PolarisX <noreply@polarisx.ltd>
CONTACT_FROM=
